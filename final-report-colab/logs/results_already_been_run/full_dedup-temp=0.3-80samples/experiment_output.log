            mod_sum = 0
            for k in range(1, 6):
                mod_val = (bin_capacity % (item + k)) / (item + k)
                if mod_val > 0.5:
                    mod_val *= 1.3
                else:
                    mod_val *= 0.9
                mod_sum += mod_val * 0.05 * k
            score += mod_sum
            if bin_capacity % 2 == 0:
