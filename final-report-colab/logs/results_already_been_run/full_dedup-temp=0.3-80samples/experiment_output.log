    for i in range(len(bins)):
        bin_capacity = bins[i]
        if bin_capacity == 0:
            priorities[i] = np.inf
            continue
        ratio = item / bin_capacity
        if ratio > 3:
            priorities[i] = ratio ** 5 - np.sqrt(ratio) + np.exp(-ratio)
        elif ratio == 3:
            priorities[i] = 2.0
        elif 2 < ratio < 3:
            priorities[i] = (ratio - 2) ** 3 * 15 + np.log1p(ratio)
        elif ratio == 2:
            priorities[i] = 1.0
        elif 1 < ratio < 2:
            priorities[i] = (ratio - 1) ** 2 * 12
        elif ratio == 1:
            priorities[i] = 0
        else:
            score = 0
            for j in range(1, 8):
                term = ((1 - ratio) ** j) / (j ** 3)
                if j % 3 == 0:
                    term *= 1.5
                elif j % 2 == 0:
                    term *= 1.2
                else:
                    term *= 0.7
                score += term
            if bin_capacity < item * 1.2:
