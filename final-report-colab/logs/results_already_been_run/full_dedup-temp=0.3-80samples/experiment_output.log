    for i in range(len(bins)):
        capacity = bins[i]
        if capacity == 0:
            continue
        ratio = item / capacity
        priority = 0.0
        if ratio > 2:
            priority = ratio ** 4 + np.sqrt(ratio)
        elif 1 < ratio <= 2:
            priority = ratio ** 3 - np.log(ratio)
