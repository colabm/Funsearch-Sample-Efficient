def priority(item: float, bins: np.ndarray) -> np.ndarray:
    """Returns priority with which we want to add item to each bin.

    Args:
        item: Size of item to be added to the bin.
        bins: Array of capacities for each bin.

    Return:
        Array of same size as bins with priority score of each bin.
    """
    priorities = np.zeros_like(bins)
    for i in range(len(bins)):
        bin_capacity = bins[i]
        if bin_capacity <= 0:
            priorities[i] = np.inf
            continue
        ratio = item / bin_capacity
        if ratio > 1:
            priorities[i] = ratio * 10
        elif 0.5 <= ratio <= 1:
            priorities[i] = -np.log(bin_capacity) + ratio * 5
        else:
            score = 0
            for j in range(1, int(bin_capacity)+1):
                if j % 2 == 0:
                    score += np.sqrt(j)
                else:
                    score -= np.log(j+1)
            priorities[i] = score / (bin_capacity + 1) + ratio
    max_priority = np.max(priorities[np.isfinite(priorities)])
    priorities = np.where(np.isinf(priorities), max_priority + 100, priorities)
    return priorities
